# PermitOS Environment Variables
# Copy this to .env.local and fill in your values
# Required variables are marked with [REQUIRED]

# ─── App ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=PermitOS
NODE_ENV=development

# ─── Authentication (Clerk) [REQUIRED for production] ──────
# Get these from https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk webhook secret — set in Clerk Dashboard → Webhooks
# Webhook URL: https://your-domain.com/api/webhooks/clerk
# Subscribe to: user.created, user.updated, user.deleted,
#   organization.created, organization.updated, organizationMembership.created
CLERK_WEBHOOK_SECRET=whsec_...

# Clerk routing (defaults — usually don't need to change)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ─── Database (PostgreSQL) [REQUIRED for production] ───────
# Neon Postgres (via Vercel Storage): pooled connection for DATABASE_URL
# and unpooled connection for DATABASE_URL_UNPOOLED (used by Prisma for migrations)
# Both are auto-set by Vercel when you connect Neon to your project
DATABASE_URL=postgresql://user:password@localhost:5432/permitos
DATABASE_URL_UNPOOLED=postgresql://user:password@localhost:5432/permitos

# ─── File Storage (future — not yet wired) ─────────────────
# S3_BUCKET_NAME=
# S3_REGION=auto
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=

# ─── Email (future — not yet wired) ────────────────────────
# RESEND_API_KEY=
# EMAIL_FROM=noreply@permitos.com

# ─── Error Tracking (optional) ─────────────────────────────
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
